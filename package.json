{
  "name": "sandpiper",
  "private": true,
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "workers",
    "localMode",
    "e2e"
  ],
  "scripts": {
    "preinstall": "node bin/setupNpmrc.js",
    "postinstall": "node bin/installBullmqPro.js",
    "app:build": "node ./app/adapters.js && react-router build",
    "app:dev": "node ./app/adapters.js && cross-env NODE_ENV=development tsx watch -r dotenv/config --import ./otel-register.mjs --import ./instrumentation.ts ./server.ts",
    "app:prod": "PORT=5173 tsx --import ./otel-register.mjs --import ./instrumentation.ts ./server.ts",
    "workers:dev": "yarn workspace sandpiper-worker dev",
    "workers:prod": "yarn workspace sandpiper-worker prod",
    "local:redis": "yarn workspace localMode redis",
    "local:start": "./localMode/bin/start-all.js",
    "seeds": "tsx -r dotenv/config ./seeds/index.ts",
    "migration:generate": "./bin/generateMigration.js",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "test:typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "test:e2e": "yarn workspace e2e test",
    "test:e2e:ui": "yarn workspace e2e test:ui",
    "test:e2e:headed": "yarn workspace e2e test:headed",
    "test:e2e:setup": "yarn workspace e2e test:setup",
    "dataset:prepare-mtm": "tsx scripts/datasets/prepareMtmDataset.ts",
    "dataset:release-mtm": "tsx scripts/datasets/releaseMtmDataset.ts"
  },
  "dependencies": {
    "@appsignal/opentelemetry-instrumentation-bullmq": "^0.8.0",
    "@aws-sdk/client-s3": "^3.864.0",
    "@aws-sdk/lib-storage": "^3.864.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "@markdoc/markdoc": "^0.5.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/instrumentation-aws-sdk": "^0.68.0",
    "@opentelemetry/instrumentation-express": "^0.61.0",
    "@opentelemetry/instrumentation-http": "^0.213.0",
    "@opentelemetry/instrumentation-ioredis": "^0.61.0",
    "@opentelemetry/instrumentation-mongodb": "^0.66.0",
    "@opentelemetry/instrumentation-mongoose": "^0.59.0",
    "@opentelemetry/instrumentation-openai": "^0.11.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.26.0",
    "@opentelemetry/instrumentation-socket.io": "^0.60.0",
    "@opentelemetry/instrumentation-undici": "^0.23.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@react-router/express": "^7.13.2",
    "@react-router/node": "^7.13.2",
    "@react-router/serve": "^7.13.2",
    "@sesamecare-oss/redlock": "^1.4.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "bullmq": "^5.61.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "csv-parse": "^6.1.0",
    "dayjs": "^1.11.18",
    "decimal.js": "^10.6.0",
    "dotenv": "^16.6.0",
    "express": "^5.1.0",
    "fs-extra": "^11.3.2",
    "gpt-tokenizer": "^3.4.0",
    "gray-matter": "^4.0.3",
    "ioredis": "^5.8.2",
    "isbot": "^5.1.27",
    "json-2-csv": "^5.5.9",
    "lodash": "^4.17.23",
    "lucide-react": "^1.7.0",
    "mongoose": "^8.18.0",
    "motion": "^12.19.1",
    "next-themes": "^0.4.6",
    "openai": "^5.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "react-router": "^7.13.2",
    "recharts": "3.8.0",
    "remix-auth": "^4.2.0",
    "remix-auth-github": "^3.0.2",
    "slugify": "^1.6.9",
    "socket.io": "^4.8.3",
    "socket.io-adapter": "^2.5.4",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.5",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.3.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "undici": "^7.16.0",
    "uuid": "^11.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css,md,yml,yaml}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@react-router/dev": "^7.13.2",
    "@tailwindcss/vite": "^4.1.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.1",
    "@types/archiver": "^6.0.3",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.5",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.17",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitest/coverage-v8": "4.0.15",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^27.3.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.0",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^6.0.1",
    "vitest": "^4.0.15"
  }
}
