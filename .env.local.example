# Sandpiper, running locally or self-hosted.
#
#   cp .env.local.example .env
#
# Then fill in the two values under "Fill these in". Everything else works as-is
# against the Mongo container described in README.LOCAL.md.
#
# This file is the local counterpart to .env.example, which documents the hosted
# deployment. Keeping them separate means upstream's .env.example stays untouched.

# --- Fill these in -----------------------------------------------------------
SESSION_SECRET=''            # openssl rand -hex 64
PROJECT_ROOT=''              # absolute path to this repo

# --- LLM provider ------------------------------------------------------------
# BEDROCK talks to AWS Bedrock directly — no gateway, no sidecar. The model codes
# in app/config/ai_gateway.json map to Bedrock inference profiles in
# app/config/bedrock_models.json.
LLM_PROVIDER='BEDROCK'
AWS_REGION='us-east-2'       # falls back to the region in bedrock_models.json

# Bedrock auth, in order of precedence. Leave all three unset to use the default
# AWS credential chain (~/.aws, IAM role) — the usual choice on a dev machine.
# BEDROCK_API_KEY=''         # a Bedrock API key (bearer token)
# AWS_KEY=''                 # ...or IAM access keys (same vars as the S3 adapter)
# AWS_SECRET=''

# --- Storage and database ----------------------------------------------------
# Session files live on disk under ./storage. Mongo runs in the sandpiper-mongo
# container; the app needs transactions, so it must be a replica set.
STORAGE_ADAPTER='LOCAL'
DOCUMENTS_ADAPTER='LOCAL'
DOCUMENT_DB_LOCAL='true'
DOCUMENT_DB_CONNECTION_STRING='localhost:27017/sandpiper?authSource=admin&directConnection=true'
DOCUMENT_DB_USERNAME='root'
DOCUMENT_DB_PASSWORD='example'

REDIS_LOCAL='true'

# --- Auth --------------------------------------------------------------------
# Local sign-in: leave GITHUB_CLIENT_ID unset and the GitHub button on /signup
# signs you in as a local super admin — no GitHub OAuth app needed.
# SUPER_ADMIN_GITHUB_ID must parse as an integer even locally: the server reads it
# on boot to seed a super admin, and a blank value crashes startup.
AUTH_CALLBACK_URL='http://localhost:5173/auth/callback'
SUPER_ADMIN_GITHUB_ID='1'

# --- Billing -----------------------------------------------------------------
# Leave BILLING_ENABLED unset. You pay your LLM provider directly, so there is
# nothing to meter; `node localMode/bin/quickstart.js` seeds a markup-free plan
# and credits so runs are never blocked. Spend is still tracked. See README.LOCAL.md.
